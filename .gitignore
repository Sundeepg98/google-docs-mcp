# Secrets — never commit
credentials/
.env
.fly-token-temp.txt

# Python
__pycache__/
*.pyc
*.pyo
*.so
.venv/
venv/
*.egg-info/
build/
dist/

# Test/coverage artifacts
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
# CI-generated artifacts that get baked into the Docker image at deploy
# time (uploaded via actions/upload-artifact). Don't commit them.
test-results.json
mutation-check.json

# Disposable local audit scratch output (audit_analysis.json,
# audit_clean.json, audit_output.json, etc.) — never commit.
audit_*.json

# Editors
.idea/
.vscode/
_full.txt
out.txt
*.log

# Local session/agent artifacts (never commit: _audit holds verification-thread
# message IDs + reply addresses; repo is public)
_audit/
.playwright-mcp/
.claude/
gcp-verification-center-*.png
